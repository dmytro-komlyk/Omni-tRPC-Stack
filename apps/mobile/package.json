{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start -c",
    "ios": "expo run:ios --no-build-cache",
    "android": "echo \"sdk.dir=$HOME/Library/Android/sdk\" > android/local.properties && expo run:android --no-build-cache",
    "clean": "rm -rf .expo .tailwind node_modules/.cache && watchman watch-del-all",
    "build": "npx expo prebuild --no-install",
    "build:apk": "eas build --platform android --profile preview",
    "build:ios": "eas build --platform ios --profile preview",
    "build:prod": "eas build --platform all",
    "build:clean": "npm run clean && rm -rf ios android && npx expo prebuild",
    "reset-project": "node ./scripts/reset-project.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@package/api": "workspace:^",
    "@package/store": "workspace:^",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.28",
    "expo": "~54.0.29",
    "expo-auth-session": "^7.0.10",
    "expo-constants": "~18.0.12",
    "expo-crypto": "^15.0.8",
    "expo-dev-client": "^6.0.20",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.20",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "toastify-react-native": "^7.2.3"
  },
  "devDependencies": {
    "@package/eslint-config": "workspace:*",
    "@package/tailwindcss-config": "workspace:*",
    "@types/react": "~19.1.0",
    "@types/react-native": "^0.73.0",
    "autoprefixer": "^10.4.24",
    "babel-preset-expo": "^54.0.10",
    "eslint": "^9.39.1",
    "eslint-config-expo": "~10.0.0",
    "nativewind": "4.2.1",
    "postcss": "^8.5.6",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "3.4.17",
    "typescript": "~5.9.2"
  },
  "private": true
}
