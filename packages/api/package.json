{
  "name": "@package/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.js",
      "require": "./dist/provider.js"
    },
    "./providerNative": {
      "types": "./dist/providerNative.d.ts",
      "import": "./dist/providerNative.js",
      "require": "./dist/providerNative.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess \"echo '✅ @package/api: Watching...'\"",
    "build:types": "tsc --emitDeclarationOnly",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@package/store": "workspace:^",
    "@tanstack/react-query": "^5.90.11",
    "@tanstack/react-query-devtools": "^5.83.0",
    "@trpc/client": "^11.4.3",
    "@trpc/next": "^11.4.3",
    "@trpc/react-query": "^11.4.3",
    "@trpc/server": "^11.4.3",
    "@trpc/tanstack-react-query": "^11.8.1",
    "axios": "^1.13.2",
    "axios-retry": "^4.5.0",
    "cron-validator": "^1.3.1",
    "expo-constants": "~18.0.12",
    "next-auth": "^5.0.0-beta.25",
    "qs": "^6.14.0",
    "react-dom": "^19.1.0",
    "superjson": "^2.2.2",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@package/eslint-config": "workspace:*",
    "@types/qs": "^6.9.18",
    "@types/react": "19.2.7",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.39.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.5.3"
  }
}
