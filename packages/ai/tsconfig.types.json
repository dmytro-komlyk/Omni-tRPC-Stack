{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,

    "declaration": true,
    "declarationMap": true,

    "rootDir": "./src",
    "outDir": "./dist",

    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo.types",
    "composite": false
  },
  "include": ["src/**/*", "../../types/globals.d.ts"]
}
