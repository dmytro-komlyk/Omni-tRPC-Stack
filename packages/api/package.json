{
  "name": "@package/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/serverClient.d.ts",
      "import": "./dist/serverClient.js"
    },
    "./provider": {
      "types": "./dist/Provider.d.ts",
      "import": "./dist/Provider.js"
    },
    "./providerNative": {
      "types": "./dist/ProviderNative.d.ts",
      "import": "./dist/ProviderNative.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:types": "tsc --emitDeclarationOnly -p tsconfig.types.json",
    "build:all": "pnpm build && pnpm build:types",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "dev": "concurrently --kill-others-on-fail -n TSUP,TYPES \"tsup --watch\" \"tsc -p tsconfig.types.json --watch --preserveWatchOutput --incremental\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@package/store": "workspace:^",
    "@tanstack/react-query": "^5.90.11",
    "@tanstack/react-query-devtools": "^5.83.0",
    "@trpc/client": "^11.4.3",
    "@trpc/next": "^11.4.3",
    "@trpc/react-query": "^11.4.3",
    "@trpc/server": "^11.4.3",
    "@trpc/tanstack-react-query": "^11.8.1",
    "axios": "^1.13.2",
    "axios-retry": "^4.5.0",
    "cron-validator": "^1.3.1",
    "expo-constants": "~18.0.12",
    "next-auth": "^5.0.0-beta.25",
    "qs": "^6.14.0",
    "react-dom": "^19.1.0",
    "server": "workspace:^",
    "superjson": "^2.2.2",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@package/eslint-config": "workspace:*",
    "@types/qs": "^6.9.18",
    "@types/react": "19.2.7",
    "@types/react-dom": "^19.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.5.3"
  }
}
