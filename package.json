{
  "name": "startap-boilerplate-next-nest-react-native-vps",
  "version": "1.0.0",
  "description": "",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "type-check": "dotenv -e .env -- turbo run type-check",
    "type-check:watch": "dotenv -e .env -- turbo run type-check --parallel --continue",
    "db:generate": "dotenv -e .env -- turbo run db:generate",
    "db:push": "dotenv -e .env -- turbo run db:push",
    "db:seed": "dotenv -e .env -- turbo run db:seed",
    "db:migrate": "dotenv -e .env -- turbo run db:migrate",
    "db:migrate:init": "dotenv -e .env -- turbo run db:migrate:init",
    "db:migrate:changes": "dotenv -e .env -- turbo run db:migrate:changes",
    "db:migrate:status": "dotenv -e .env -- turbo run db:migrate:status",
    "db:migrate:deploy": "dotenv -e .env -- turbo run db:migrate:deploy",
    "db:full": "dotenv -e .env -- turbo run db:full",
    "db:reset": "dotenv -e .env -- turbo run db:reset",
    "db:studio": "dotenv -e .env -- turbo run studio",
    "build": "dotenv -e .env -- turbo run build --parallel --filter=website... --filter=admin... --filter=server...",
    "build:packages": "dotenv -e .env -- turbo run build --filter=@package/*...",
    "build:website": "dotenv -e .env -- turbo run build --filter=website...",
    "build:admin": "dotenv -e .env -- turbo run build --filter=admin...",
    "build:server": "dotenv -e .env -- turbo run build --filter=server...",
    "build:mobile": "dotenv -e .env -- turbo run build --filter=mobile...",
    "build:mobile+server": "dotenv -e .env -- turbo run build --parallel --filter=mobile... --filter=server...",
    "dev": "dotenv -e .env -- turbo run dev --parallel --filter=website... --filter=admin... --filter=server...",
    "dev:website": "dotenv -e .env -- turbo run dev --parallel --filter=website... --filter=server...",
    "dev:admin": "dotenv -e .env -- turbo run dev --parallel --filter=admin... --filter=server...",
    "dev:mobile": "dotenv -e .env -- turbo run dev --parallel --filter=mobile... --filter=server...",
    "dev:server": "dotenv -e .env -- turbo run dev --filter=server...",
    "start": "dotenv -e .env -- turbo run start --filter=website... --filter=admin... --filter=server...",
    "start:website": "dotenv -e .env -- turbo run start --parallel --filter=website... --filter=server...",
    "start:admin": "dotenv -e .env -- turbo run start --parallel --filter=admin... --filter=server...",
    "start:mobile": "dotenv -e .env -- turbo run start --parallel --filter=mobile... --filter=server...",
    "start:server": "dotenv -e .env -- turbo run start --filter=server...",
    "lint": "turbo run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "clean": "dotenv -e .env -- turbo run clean",
    "clean:cache": "rm -rf node_modules/.cache .turbo",
    "format": "prettier --write . --ignore-path .gitignore --ignore-path packages/prisma/schema.prisma",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "Dmytro Komlyk <dima.komlyk@gmail.com>",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/cz-commitlint": "^20.1.0",
    "commitizen": "^4.3.0",
    "dotenv-cli": "^11.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "next-auth": "5.0.0-beta.25",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "turbo": "^2.6.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,jsonc,md,mdx,yml,yaml}": "prettier --write",
    "*.{css,scss,less}": "prettier --write",
    "*.prisma": "prettier --write",
    "**/*.d.ts": "prettier --write"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "packageManager": "pnpm@10.12.1+sha512.f0dda8580f0ee9481c5c79a1d927b9164f2c478e90992ad268bbb2465a736984391d6333d2c327913578b2804af33474ca554ba29c04a8b13060a717675ae3ac",
  "prepare": "husky"
}
