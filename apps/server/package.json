{
  "name": "server",
  "version": "0.1.0",
  "description": "Server based on Nestjs, tRPC",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:prod": "node dist/main",
    "dev": "nest start --watch | pino-pretty -c -t 'SYS:HH:mm:ss' -i pid,hostname --singleLine false",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/websocket": "^11.0.2",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.0.6",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.6",
    "@nestjs/platform-fastify": "^11.1.3",
    "@package/prisma": "workspace:*",
    "@trpc/server": "^11.4.3",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "cache-manager": "^7.0.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.5.0",
    "fastify": "^5.4.0",
    "google-auth-library": "^10.5.0",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.3",
    "nestjs-pino": "^4.4.0",
    "nodemailer": "^7.0.11",
    "pino-pretty": "^13.1.3",
    "trpc-to-openapi": "^3.1.0",
    "ws": "^8.18.1",
    "zod": "^4.0.0"
