{
  "name": "@package/ui",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./theme-server": {
      "require": "./dist/theme-server.js",
      "types": "./dist/theme-server.d.ts"
    },
    "./theme-cookie": {
      "require": "./dist/theme-cookie.js",
      "types": "./dist/theme-cookie.d.ts"
    },
    "./ThemeProvider": {
      "require": "./dist/ThemeProvider.js",
      "types": "./dist/ThemeProvider.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess \"echo '✅ @package/ui: Watching...'\"",
    "build:types": "tsc --emitDeclarationOnly",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@package/store": "workspace:^",
    "js-cookie": "^3.0.5",
    "next": "16.0.4",
    "next-themes": "^0.4.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "peerDependencies": {
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@package/eslint-config": "workspace:*",
    "@types/react": "19.2.7",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3"
  }
}
