{
  "name": "@package/ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:types": "tsc --emitDeclarationOnly -p tsconfig.types.json",
    "build:all": "pnpm build && pnpm build:types",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "dev": "concurrently --kill-others-on-fail -n TSUP,TYPES \"tsup --watch\" \"tsc -p tsconfig.types.json --watch --preserveWatchOutput --incremental\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "ai": "^6.0.116",
    "ollama-ai-provider-v2": "^3.5.0"
  },
  "devDependencies": {
    "@package/eslint-config": "workspace:*",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.5.3"
  }
}
